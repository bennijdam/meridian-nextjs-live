# =============================================================
# Meridian London — environment variables
# Copy this file to `.env.local` and fill in real values.
# Never commit `.env.local` to git.
# =============================================================

# --- Site ---
NEXT_PUBLIC_SITE_URL=https://www.meridianweb.co.uk
NEXT_PUBLIC_SITE_NAME=Meridian

# --- Resend (transactional email + audit delivery) ---
# Get key: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxxxxx
RESEND_FROM_EMAIL=audits@meridianweb.co.uk
RESEND_REPLY_TO=hello@meridianweb.co.uk

# --- Neon Postgres (lead storage) ---
# Get connection string: https://console.neon.tech
DATABASE_URL=postgresql://user:pass@ep-xxx.eu-west-2.aws.neon.tech/meridian?sslmode=require

# --- Upstash Redis (rate limiting on /api/audit) ---
# Get URL + token: https://console.upstash.com/redis
UPSTASH_REDIS_REST_URL=https://xxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxx

# --- Google APIs (for live SEO audit data — optional) ---
PAGESPEED_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxxx
GOOGLE_SEARCH_CONSOLE_SERVICE_ACCOUNT_JSON='{"type":"service_account",...}'

# --- Analytics (optional, but enabled in layout.tsx if set) ---
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=www.meridianweb.co.uk

# --- Slack lead notification (optional) ---
SLACK_LEADS_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ

# --- HubSpot CRM (optional — sync leads to CRM automatically) ---
# Get token: https://app.hubspot.com/settings/ > Integrations > Private Apps
# Required scopes: crm.objects.contacts.write, crm.objects.deals.write
HUBSPOT_ACCESS_TOKEN=pat-xxxxxxxxxxxxxxxxxxxx
HUBSPOT_PORTAL_ID=12345678


# --- Stripe (payments + subscriptions) ---
# https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# Stripe price IDs — one per (service tier × billing period).
# Generate these in Stripe dashboard or via the script in scripts/setup-stripe.mjs
# Pattern: STRIPE_PRICE_<SERVICE>_<TIER>_<PERIOD>

# SEO retainers
STRIPE_PRICE_SEO_STARTER_PAYG=price_xxx
